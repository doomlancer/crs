# Karneval Reservierungssystem - Apache Konfiguration

Options -Indexes -FollowSymLinks

# PHP-Fehlerseiten
ErrorDocument 403 /pages/error_403.php
ErrorDocument 404 /pages/error_404.php

# Uploads-Verzeichnis vor direktem Zugriff schützen
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^uploads/(.*)$ - [F,L]
</IfModule>

# PHP-Dateien in uploads/ sperren (ohne <Directory>)
<FilesMatch "^uploads/.*\.php$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Sensible Dateien sperren
<FilesMatch "\.(sql|log|env|ini|conf|bak)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Security Headers
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdn.jsdelivr.net; style-src 'self' https://cdn.jsdelivr.net https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
</IfModule>

# Caching für statische Assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

# Komprimierung
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>
